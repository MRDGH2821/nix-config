[
  {
    "allow_concurrent_runs": false,
    "args": ["$ZED_FILE"],
    "command": ".zed/c2n.sh",
    "cwd": "$ZED_WORKTREE_ROOT",
    "hide": "on_success",
    "label": "Generate podman-compose.nix",
    "shell": "system"
  },
  {
    "allow_concurrent_runs": false,
    "args": ["$ZED_WORKTREE_ROOT"],
    "command": ".zed/c2n.sh",
    "cwd": "$ZED_WORKTREE_ROOT",
    "hide": "never",
    "label": "Generate all podman-compose.nix",
    "shell": "system"
  },
  {
    "args": ["$ZED_FILE"],
    "command": "sops",
    "env": {
      "EDITOR": "zed --wait"
    },
    "label": "Open SOPS Encrypted file",
    "shell": "system"
  },
  {
    "command": ".zed/update-flake.lock.sh",
    "hide": "on_success",
    "label": "Update flake.lock"
  }
]
